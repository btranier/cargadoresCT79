# Copy to saci.env and: set -a; source saci.env; set +a
GATEWAYS=192.168.1.100:502,192.168.1.101:502,192.168.1.102:502,192.168.1.103:502
UNITS=1-32
DISABLE_POLLER=0
POLL_INTERVAL_SEC=900
SEED_ON_BOOT=1
RESEED_FULL=1
IMPORT_READINGS_ON_START=0
# SACI registers (zero-based)
REG_VOLT_ADDR=256
REG_VOLT_COUNT=2
REG_VOLT_TYPE=uint32_be_scale_0p001
REG_CURR_ADDR=258
REG_CURR_COUNT=2
REG_CURR_TYPE=int32_be_scale_0p001
REG_PWR_ADDR=260
REG_PWR_COUNT=2
REG_PWR_TYPE=int32_be_scale_0p001
REG_FREQ_ADDR=266
REG_FREQ_COUNT=1
REG_FREQ_TYPE=u16_scale_0p1
REG_PF_ADDR=267
REG_PF_COUNT=1
REG_PF_TYPE=u16_scale_0p001
REG_KWH_ADDR=270
REG_KWH_COUNT=2
REG_KWH_TYPE=uint32_be_scale_0p01
